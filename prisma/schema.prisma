// Prisma schema for Wall of Shame tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductType {
  CIGARETTE
  CIGAR
  CHEW
  SHISHA
  VAPE
}

enum RewardType {
  BADGE
  TREAT
  STREAK
}

model Person {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  slips     Slip[]
  crises    Crisis[]
}

model Slip {
  id          String      @id @default(cuid())
  personId    String
  person      Person      @relation(fields: [personId], references: [id])
  occurredAt  DateTime
  amount      Int
  productType ProductType
  createdAt   DateTime    @default(now())

  @@index([personId])
  @@index([occurredAt])
}

model Crisis {
  id           String      @id @default(cuid())
  personId     String
  person       Person      @relation(fields: [personId], references: [id])
  occurredAt   DateTime
  cravingType  ProductType
  amount       Int
  note         String
  rewardType   RewardType
  rewardLabel  String
  createdAt    DateTime    @default(now())

  @@index([personId])
  @@index([occurredAt])
}
